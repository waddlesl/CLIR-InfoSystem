<div class="container mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold mb-0">Activity History</h4>
            <small class="text-muted">@DateTime.Now.ToString("MMM dd, yyyy | dddd, h:mm tt")</small>
        </div>
        <div class="input-group" style="max-width: 300px;">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="unifiedSearch" class="form-control border-start-0" placeholder="Search history...">
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="d-flex bg-light p-2 gap-2 justify-content-center rounded">
            <button class="gray-tab-btn rounded-pill active-gray" onclick="showTab(event,'books')">
                <i class="fa-solid fa-book me-1"></i> Books
            </button>
            <button class="gray-tab-btn rounded-pill" onclick="showTab(event,'seats')">
                <i class="fa-solid fa-chair me-1"></i> Seats
            </button>
            <button class="gray-tab-btn rounded-pill" onclick="showTab(event,'odds')">
                <i class="fa-solid fa-file-invoice me-1"></i> ODDS
            </button>
            <button class="gray-tab-btn rounded-pill" onclick="showTab(event,'consult')">
                <i class="fa-solid fa-chalkboard-user me-1"></i> Consultations
            </button>
        </div>

        <div class="card-body p-4">

            <div id="books" class="tab-pane-custom">
                <div class="table-responsive">
                    <table class="table align-middle mb-0" id="booksTable">
                        <thead class="small text-muted">
                            <tr>
                                <th>Book Title</th>
                                <th>Borrow Date</th>
                                <th>Due Date</th>
                                <th class="text-end">Status</th>
                            </tr>
                        </thead>
                        <tbody id="booksBody">
                            @foreach (var loan in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@loan.Book?.Title</td>
                                    <td>@loan.BorrowDate.ToString("MMM dd, yyyy")</td>
                                    <td>@(loan.Status == "Reserved" ? "---" : loan.DueDate?.ToString("MMM dd, yyyy"))</td>
                                    <td class="text-end">
                                        @{
                                            string bookClass = loan.Status switch
                                            {
                                                "Returned" => "success",
                                                "Borrowed" => "info",
                                                "Reserved" => "warning",
                                                "Overdue" or "Cancelled" or "Rejected" or "Denied" => "danger",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="capsule capsule-@bookClass">@loan.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div id="booksPageInfo" class="small text-muted"></div>
                    <ul class="pagination pagination-sm mb-0" id="booksPagination"></ul>
                </div>
            </div>

            <div id="seats" class="tab-pane-custom" style="display:none">
                <div class="table-responsive">
                    <table class="table align-middle mb-0" id="seatsTable">
                        <thead class="small text-muted">
                            <tr>
                                <th>Date</th>
                                <th>Slot</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody id="seatsBody">
                            @if (ViewBag.SeatHistory != null)
                            {
                                foreach (var item in ViewBag.SeatHistory)
                                {
                                    <tr>
                                        <td>@item.BookingDate.ToShortDateString()</td>
                                        <td>@item.TimeSlot?.DisplayText</td>
                                        <td class="text-center">
                                            @{
                                                string seatClass = item.Status == "Completed" ? "success" : (item.Status == "Cancelled" || item.Status == "Rejected" || item.Status == "Denied" ? "danger" : "primary");
                                            }
                                            <span class="capsule capsule-@seatClass">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div id="seatPageInfo" class="small text-muted"></div>
                    <ul class="pagination pagination-sm mb-0" id="seatPagination"></ul>
                </div>
            </div>

            <div id="odds" class="tab-pane-custom" style="display:none">
                <div class="table-responsive">
                    <table class="table align-middle mb-0" id="oddsTable">
                        <thead class="small text-muted">
                            <tr>
                                <th>Material</th>
                                <th>Request Date</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody id="oddsBody">
                            @if (ViewBag.OddsHistory != null)
                            {
                                foreach (var item in ViewBag.OddsHistory)
                                {
                                    <tr>
                                        <td>@item.MaterialType</td>
                                        <td>@item.RequestDate.ToShortDateString()</td>
                                        <td class="text-center">
                                            @{
                                                string oddsClass = (item.RequestStatus == "Fulfilled" || item.RequestStatus == "Completed") ? "success" : (item.RequestStatus == "Cancelled" || item.RequestStatus == "Rejected" || item.RequestStatus == "Denied" ? "danger" : (item.RequestStatus == "Pending" ? "warning" : "info"));
                                            }
                                            <span class="capsule capsule-@oddsClass">@item.RequestStatus</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div id="oddsPageInfo" class="small text-muted"></div>
                    <ul class="pagination pagination-sm mb-0" id="oddsPagination"></ul>
                </div>
            </div>

            <div id="consult" class="tab-pane-custom" style="display:none">
                <div class="table-responsive">
                    <table class="table align-middle mb-0" id="consultTable">
                        <thead class="small text-muted">
                            <tr>
                                <th>Topic</th>
                                <th>Date</th>
                                <th>Librarian</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody id="consultBody">
                            @if (ViewBag.ConsultationHistory != null)
                            {
                                foreach (var item in ViewBag.ConsultationHistory)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Topic</td>
                                        <td>@item.BookingDate.ToString("MMM dd, yyyy")</td>
                                        <td>@(item.Staff?.FirstName ?? "TBD")</td>
                                        <td class="text-center">
                                            @{
                                                string cClass = (item.Status == "Approved" || item.Status == "Completed") ? "success" :
                                                (item.Status == "Cancelled" || item.Status == "Rejected") ? "danger" : "info";
                                            }
                                            <span class="capsule capsule-@cClass">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div id="consultPageInfo" class="small text-muted"></div>
                    <ul class="pagination pagination-sm mb-0" id="consultPagination"></ul>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(evt, tabName) {
            document.querySelectorAll(".tab-pane-custom").forEach(t => t.style.display = "none");
            document.querySelectorAll(".gray-tab-btn").forEach(b => b.classList.remove("active-gray"));
            document.getElementById(tabName).style.display = "block";
            evt.currentTarget.classList.add("active-gray");
        }

        document.getElementById("unifiedSearch").addEventListener("keyup", function () {
            let val = this.value.toLowerCase();
            let activeTable = document.querySelector(".tab-pane-custom:not([style*='none'])");
            let rows = activeTable.querySelectorAll("tbody tr");
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(val) ? "" : "none";
            });
        });

        function paginateTable(tableBodyId, paginationId, pageInfoId, rowsPerPage = 5) {
            let tbody = document.getElementById(tableBodyId);
            if (!tbody) return;
            let rows = Array.from(tbody.querySelectorAll("tr"));
            let totalRows = rows.length;
            let totalPages = Math.ceil(totalRows / rowsPerPage);
            let pagination = document.getElementById(paginationId);
            let pageInfo = document.getElementById(pageInfoId);

            function showPage(page) {
                rows.forEach((r, i) => r.style.display = (i >= (page - 1) * rowsPerPage && i < page * rowsPerPage) ? "" : "none");
                if (pageInfo) {
                    let start = totalRows > 0 ? (page - 1) * rowsPerPage + 1 : 0;
                    let end = Math.min(page * rowsPerPage, totalRows);
                    pageInfo.textContent = `Showing ${start} to ${end} of ${totalRows} entries`;
                }
            }

            pagination.innerHTML = "";
            for (let i = 1; i <= totalPages; i++) {
                let li = document.createElement("li");
                li.className = "page-item";
                let btn = document.createElement("button");
                btn.className = "page-link";
                btn.innerText = i;
                btn.addEventListener("click", () => {
                    pagination.querySelectorAll(".page-item").forEach(p => p.classList.remove("active"));
                    li.classList.add("active");
                    showPage(i);
                });
                li.appendChild(btn);
                pagination.appendChild(li);
            }
            if (totalPages > 0) { pagination.querySelector("li").classList.add("active"); showPage(1); }
        }

        document.addEventListener("DOMContentLoaded", function () {
            paginateTable("booksBody", "booksPagination", "booksPageInfo");
            paginateTable("seatsBody", "seatPagination", "seatPageInfo");
            paginateTable("oddsBody", "oddsPagination", "oddsPageInfo");
            paginateTable("consultBody", "consultPagination", "consultPageInfo");
        });
    </script>

    <style>
        .gray-tab-btn {
            flex: 1;
            padding: 10px 15px;
            background: #f8f9fa;
            border: none;
            font-weight: 600;
            transition: all 0.3s;
            color: #6c757d;
        }

            .gray-tab-btn:hover {
                background: #e2e3e5;
                color: #333;
            }

            .gray-tab-btn.active-gray {
                background: #ffffff !important;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                color: #1e2953;
            }

        .capsule {
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            min-width: 85px;
            text-align: center;
        }

        .capsule-success {
            background: #d1e7dd;
            color: #0f5132;
        }

        .capsule-primary {
            background: #cfe2ff;
            color: #084298;
        }

        .capsule-info {
            background: #cff4fc;
            color: #055160;
        }

        .capsule-warning {
            background: #fff3cd;
            color: #664d03;
        }

        .capsule-danger {
            background: #f8d7da;
            color: #842029;
        }
        /* Red for Rejected/Cancelled */
        .page-item.active .page-link {
            background-color: #1a2035 !important;
            border-color: #1a2035 !important;
            color: white !important;
        }

        .page-link {
            color: #1a2035;
        }
    </style>
}